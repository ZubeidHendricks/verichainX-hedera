{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "main_tidb.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "main_tidb.py" },
    { "src": "/docs", "dest": "main_tidb.py" },
    { "src": "/redoc", "dest": "main_tidb.py" },
    { "src": "/openapi.json", "dest": "main_tidb.py" },
    { "src": "/health", "dest": "main_tidb.py" },
    { "src": "/livez", "dest": "main_tidb.py" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "env": {
    "VITE_API_BASE_URL": "https://verichain-x-hedera.vercel.app",
    "PYTHONPATH": ".",
    "ENVIRONMENT": "production",
    "HACKATHON_MODE": "true",
    "HEDERA_NETWORK": "testnet"
  }
}
